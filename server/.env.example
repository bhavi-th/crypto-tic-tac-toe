# TicTacToe Arena Backend environment variables — copy to .env and fill in real values
MONGODB_URL=your_mongodb_connection_string
PORT=3000
JWT_SECRETKEY=any_long_random_string_for_jwt_signing

# Contract configuration for event listening
CONTRACT_ADDRESS=your_deployed_tictactoe_contract_address
RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
